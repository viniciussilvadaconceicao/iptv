WA_MAX_DELAY_MS=15000
WA_ENABLE=true
WA_SESSION_PATH=C:\wa-session-loja
WA_HEADLESS=false
# WA_CHROME_PATH desativado para não usar o Chrome principal do sistema
#WA_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
ADMIN_PHONE=5522998084652
PGURL=postgres://postgres:pgadmin@localhost:5432/bot-iptv
DATABASE_URL=postgres://postgres:pgadmin@localhost:5432/bot-iptv
DUE_NOTIFIER_QUERY=select telefone as phone, split_part(cliente,' ',1) as first_name, case when position(' ' in cliente)>0 then substring(cliente from position(' ' in cliente)+1) else '' end as last_name, encerra_em as end_date, plano as plan_duration_label, qtde_telas as plan_screens_count, dias_restantes as days_remaining from vw_relatorio_clientes where encerra_em is not null and status_plano='active' and dias_restantes in (0,1)
